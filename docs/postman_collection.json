    {
      "name": "💰 VENTAS",
      "item": [
        {
          "name": "PRUEBA 1 – GET Listar ventas con resumen",
          "request": { "method": "GET", "url": "{{base_url}}/ventas",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [{"name":"200 OK","code":200,"body":"{\"data\":[],\"resumen\":{\"total_ventas\":0,\"unidades_vendidas\":0,\"ingresos_totales\":0}}"}]
        },
        {
          "name": "PRUEBA 2 – POST Registrar venta",
          "request": { "method": "POST", "url": "{{base_url}}/ventas",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Accept","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"cliente_id\": 1,\n  \"camiseta_id\": 1,\n  \"talla_id\": 2,\n  \"cantidad\": 5,\n  \"observaciones\": \"Pedido urgente apertura de tienda\"\n}"}},
          "response": [
            {"name":"201 Created","code":201,"body":"{\"data\":{\"id\":1,\"total_venta\":190000},\"resumen\":{\"precio_base\":45000,\"precio_final\":38000,\"descuento_aplicado\":\"precio_oferta\",\"porcentaje_ahorro\":\"15.56%\",\"total_venta\":190000}}"},
            {"name":"409 Stock insuficiente","code":409,"body":"{\"message\":\"Stock insuficiente para la talla seleccionada.\",\"stock_disponible\":3}"}
          ]
        },
        {
          "name": "PRUEBA 3 – GET Estadísticas de ventas",
          "request": { "method": "GET", "url": "{{base_url}}/ventas/estadisticas",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [{"name":"200 OK","code":200,"body":"{\"totales\":{\"ventas_confirmadas\":1,\"unidades_totales\":5,\"ingresos_totales\":190000},\"por_camiseta\":[{\"camiseta_id\":1,\"unidades_vendidas\":5}],\"por_cliente\":[{\"cliente_id\":1,\"total_gastado\":190000}]}"}]
        },
        {
          "name": "PRUEBA 4 – GET Ver detalle de venta",
          "request": { "method": "GET", "url": "{{base_url}}/ventas/1",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [{"name":"200 OK","code":200,"body":"{\"data\":{\"id\":1,\"cantidad\":5,\"total_venta\":190000,\"estado\":\"confirmada\"}}"}]
        },
        {
          "name": "PRUEBA 5 – PATCH Cambiar estado de venta",
          "request": { "method": "PATCH", "url": "{{base_url}}/ventas/1",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Accept","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"estado\": \"anulada\",\n  \"observaciones\": \"Cliente canceló el pedido\"\n}"}},
          "response": [{"name":"200 OK","code":200,"body":"{\"data\":{\"estado\":\"anulada\"},\"message\":\"Venta actualizada correctamente.\"}"}]
        },
        {
          "name": "PRUEBA 6 – DELETE Eliminar venta (solo pendientes)",
          "request": { "method": "DELETE", "url": "{{base_url}}/ventas/1",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [
            {"name":"200 OK","code":200,"body":"{\"message\":\"Venta eliminada correctamente.\"}"},
            {"name":"409 Confirmada","code":409,"body":"{\"message\":\"No se puede eliminar una venta confirmada. Use PATCH para cambiar el estado a \\\"anulada\\\".\"}"}
          ]
        }
      ]
    }

  ]
