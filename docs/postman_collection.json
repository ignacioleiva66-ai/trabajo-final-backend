{
  "info": {
    "name": "TodoCamisetas API v2",
    "description": "Colección completa. Importar en Postman: File → Import → seleccionar este archivo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api", "type": "string" }
  ],
  "item": [

    {
      "name": "🧢 CAMISETAS",
      "item": [
        {
          "name": "PRUEBA 1 – GET Listar camisetas",
          "request": { "method": "GET", "url": "{{base_url}}/camisetas",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [{"name":"200 OK","status":"OK","code":200,
            "body":"{\"data\":[{\"id\":1,\"titulo\":\"Camiseta Local 2025\",\"precio\":\"45000.00\",\"tallas\":[{\"id\":2,\"nombre\":\"M\",\"pivot\":{\"stock\":20}}]}]}"}]
        },
        {
          "name": "PRUEBA 2 – POST Crear camiseta",
          "request": { "method": "POST", "url": "{{base_url}}/camisetas",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Accept","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"titulo\": \"Camiseta Local 2025 – Selección Chilena\",\n  \"club\": \"Selección Chilena\",\n  \"pais\": \"Chile\",\n  \"tipo\": \"Local\",\n  \"color\": \"Rojo y Azul\",\n  \"precio\": 45000,\n  \"precio_oferta\": 38000,\n  \"detalles\": \"Edición aniversario 2025\",\n  \"codigo_producto\": \"SCL2025L\",\n  \"tallas\": [\n    {\"talla_id\": 1, \"stock\": 10},\n    {\"talla_id\": 2, \"stock\": 20}\n  ]\n}"}},
          "response": [
            {"name":"201 Created","status":"Created","code":201,"body":"{\"data\":{\"id\":1,\"titulo\":\"Camiseta Local 2025 – Selección Chilena\",\"codigo_producto\":\"SCL2025L\"},\"message\":\"Camiseta creada correctamente.\"}"},
            {"name":"422 Validation Error","status":"Unprocessable Entity","code":422,"body":"{\"message\":\"Error de validación.\",\"errors\":{\"titulo\":[\"El campo titulo es requerido.\"]}}"}
          ]
        },
        {
          "name": "PRUEBA 3 – GET Ver camiseta por ID",
          "request": { "method": "GET", "url": "{{base_url}}/camisetas/1",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [
            {"name":"200 OK","status":"OK","code":200,"body":"{\"data\":{\"id\":1,\"titulo\":\"Camiseta Local 2025\"}}"},
            {"name":"404 Not Found","status":"Not Found","code":404,"body":"{\"message\":\"Camiseta no encontrada.\"}"}
          ]
        },
        {
          "name": "PRUEBA 4 – PUT Actualizar camiseta",
          "request": { "method": "PUT", "url": "{{base_url}}/camisetas/1",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Accept","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"precio\": 48000,\n  \"precio_oferta\": 40000,\n  \"tallas\": [{\"talla_id\": 2, \"stock\": 25}]\n}"}},
          "response": [{"name":"200 OK","status":"OK","code":200,"body":"{\"data\":{\"id\":1,\"precio\":\"48000.00\"},\"message\":\"Camiseta actualizada correctamente.\"}"}]
        },
        {
          "name": "PRUEBA 5 – PATCH Actualizar campo específico",
          "request": { "method": "PATCH", "url": "{{base_url}}/camisetas/1",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Accept","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"precio_oferta\": 36000\n}"}},
          "response": [{"name":"200 OK","status":"OK","code":200,"body":"{\"data\":{\"precio_oferta\":\"36000.00\"},\"message\":\"Camiseta actualizada correctamente.\"}"}]
        },
        {
          "name": "PRUEBA 6 – DELETE Eliminar camiseta",
          "request": { "method": "DELETE", "url": "{{base_url}}/camisetas/1",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [{"name":"200 OK","status":"OK","code":200,"body":"{\"message\":\"Camiseta eliminada correctamente.\"}"}]
        },
        {
          "name": "EXTRA – GET Precio final (cliente preferencial)",
          "request": { "method": "GET",
            "url": {"raw":"{{base_url}}/camisetas/1/precio?cliente_id=1","query":[{"key":"cliente_id","value":"1"}]},
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [{"name":"200 Preferencial","status":"OK","code":200,"body":"{\"data\":{\"precio_final\":38000,\"descuento_aplicado\":\"precio_oferta\",\"cliente_categoria\":\"Preferencial\"}}"},
            {"name":"200 Regular","status":"OK","code":200,"body":"{\"data\":{\"precio_final\":45000,\"descuento_aplicado\":\"ninguno\",\"cliente_categoria\":\"Regular\"}}"}]
        }
      ]
    },

    {
      "name": "👥 CLIENTES",
      "item": [
        {
          "name": "PRUEBA 1 – GET Listar clientes",
          "request": { "method": "GET", "url": "{{base_url}}/clientes",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [{"name":"200 OK","status":"OK","code":200,"body":"{\"data\":[{\"id\":1,\"nombre_comercial\":\"90minutos\",\"categoria\":\"Preferencial\"}],\"total\":2}"}]
        },
        {
          "name": "PRUEBA 2 – POST Crear cliente (RUT válido)",
          "request": { "method": "POST", "url": "{{base_url}}/clientes",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Accept","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"nombre_comercial\": \"90minutos\",\n  \"rut\": \"76.123.456-7\",\n  \"direccion\": \"Providencia, Santiago\",\n  \"categoria\": \"Preferencial\",\n  \"contacto_nombre\": \"Pedro Rojas\",\n  \"contacto_email\": \"compras@90minutos.cl\",\n  \"porcentaje_oferta\": 15\n}"}},
          "response": [
            {"name":"201 Created","status":"Created","code":201,"body":"{\"data\":{\"id\":1,\"nombre_comercial\":\"90minutos\",\"rut\":\"76.123.456-7\"},\"message\":\"Cliente creado correctamente.\"}"},
            {"name":"422 RUT inválido","status":"Unprocessable Entity","code":422,"body":"{\"message\":\"El RUT ingresado no es válido.\",\"rut\":\"12.345.678-0\"}"}
          ]
        },
        {
          "name": "PRUEBA 3 – GET Ver cliente con contactos",
          "request": { "method": "GET", "url": "{{base_url}}/clientes/1",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [{"name":"200 OK","code":200,"body":"{\"data\":{\"id\":1,\"nombre_comercial\":\"90minutos\",\"contactos_empresa\":[],\"contactos_personal\":[]}}"}]
        },
        {
          "name": "PRUEBA 4 – PUT Actualizar cliente",
          "request": { "method": "PUT", "url": "{{base_url}}/clientes/1",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Accept","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"porcentaje_oferta\": 20,\n  \"categoria\": \"Preferencial\"\n}"}},
          "response": [{"name":"200 OK","code":200,"body":"{\"data\":{\"porcentaje_oferta\":\"20.00\"},\"message\":\"Cliente actualizado correctamente.\"}"}]
        },
        {
          "name": "PRUEBA 5 – PATCH Actualizar campo específico",
          "request": { "method": "PATCH", "url": "{{base_url}}/clientes/1",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Accept","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"porcentaje_oferta\": 25\n}"}},
          "response": [{"name":"200 OK","code":200,"body":"{\"data\":{\"porcentaje_oferta\":\"25.00\"},\"message\":\"Cliente actualizado correctamente.\"}"}]
        },
        {
          "name": "PRUEBA 6 – DELETE Eliminar cliente",
          "request": { "method": "DELETE", "url": "{{base_url}}/clientes/1",
            "header": [{"key":"Accept","value":"application/json"}] },
          "response": [
            {"name":"200 OK","code":200,"body":"{\"message\":\"Cliente eliminado correctamente.\"}"},
            {"name":"409 Con ventas","code":409,"body":"{\"message\":\"No se puede eliminar el cliente porque tiene ventas registradas.\"}"}
          ]
        }
      ]
    },

